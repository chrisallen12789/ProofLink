# ProofLink test environment template
# Copy to .env.test and fill with a non-production Supabase project and test users.

TEST_SUPABASE_URL=https://your-project.supabase.co
TEST_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TEST_SUPABASE_ANON_KEY=your-anon-key
TEST_SITE_URL=http://127.0.0.1:8888

TEST_PLATFORM_ADMIN_EMAIL=platform-admin@example.com
TEST_PLATFORM_ADMIN_PASSWORD=change-me
TEST_TENANT_A_ADMIN_EMAIL=tenant-a-admin@example.com
TEST_TENANT_A_ADMIN_PASSWORD=change-me
TEST_TENANT_B_ADMIN_EMAIL=tenant-b-admin@example.com
TEST_TENANT_B_ADMIN_PASSWORD=change-me
