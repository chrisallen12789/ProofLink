{
  "name": "prooflink-functions",
  "version": "1.0.0",
  "description": "ProofLink serverless functions",
  "private": true,
  "scripts": {
    "dev:test": "node scripts/start-test-netlify-dev.js",
    "lint": "eslint netlify/functions scripts tests *.js --ext .js",
    "test": "vitest run tests/unit tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:preflight:env-contract": "node scripts/verify-test-env-contract.js",
    "test:preflight:service-workflow": "npm run test:preflight:env-contract && node tests/setup/run-service-workflow-preflight.js",
    "test:integration:service-workflow": "npm run test:preflight:service-workflow && vitest run tests/integration/netlify/functions/service-intake.int.test.js tests/integration/sql/service-workflow.int.test.js",
    "test:github-actions-status": "node scripts/check-github-actions-status.js",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:e2e:operator-cross-device": "npm run test:seed && playwright test tests/e2e/operator-cross-device-smoke.spec.js tests/e2e/operator-authenticated-cross-device.spec.js --config=playwright.config.js",
    "test:e2e:service-workflow": "npm run test:preflight:service-workflow && playwright test tests/e2e/service-workflow.spec.js --config=playwright.config.js",
    "test:e2e:headed": "playwright test --config=playwright.config.js --headed",
    "test:seed": "tsx tests/seeds/seed-test-foundation.js",
    "test:cleanup": "tsx tests/seeds/cleanup-test-foundation.js",
    "sql:build:rebuild": "node scripts/build-supabase-rebuild-sql.js",
    "capture:landing-shots": "node scripts/capture-landing-shots.js",
    "test:all": "npm run test:cleanup && npm run test:seed && npm run test:preflight:service-workflow && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "stripe": "^20.4.1",
    "twilio": "^5.3.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.2",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.54.2",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
