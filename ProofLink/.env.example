# ProofLink — Required Environment Variables
# Set all of these in your Netlify dashboard:
# Site → Environment variables
#
# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_1TAcWbDvhvAaxXasbIDUK1aO
STRIPE_PRICE_GROWTH_MONTHLY=price_1T8nOODvhvAaxXasqGKnuH85

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ANON_KEY=...

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=...
FROM_EMAIL=ProofLink <support@prooflink.co>
REPLY_TO_EMAIL=support@prooflink.co
MAIL_FROM=ProofLink <support@prooflink.co>
MAIL_TO=christopher@prooflink.co
OPERATOR_ALERT_EMAIL=christopher@prooflink.co

# ── Domain ─────────────────────────────────────────────────────────────────────
# SITE_URL must be the canonical domain — used in auth redirect links, emails, etc.
SITE_URL=https://prooflink.co
PUBLIC_SITE_URL=https://prooflink.co

# ── Platform ───────────────────────────────────────────────────────────────────
INTERNAL_SECRET=...
PLATFORM_NAME=ProofLink
MAX_TESTER_SLOTS=3

# ── Spam protection ────────────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=...
