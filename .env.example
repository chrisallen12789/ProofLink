# ProofLink — Required Environment Variables
# Set all of these in your Netlify dashboard:
# Site → Environment variables
#
# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                         # Your Stripe secret key (test or live)
STRIPE_WEBHOOK_SECRET=whsec_...                       # Platform webhook signing secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...               # Connect webhook signing secret

# Subscription price IDs (Test mode — swap for live price IDs when going live)
STRIPE_PRICE_STARTER_MONTHLY=price_1TAcWbDvhvAaxXasbIDUK1aO
STRIPE_PRICE_GROWTH_MONTHLY=price_1T8nOODvhvAaxXasqGKnuH85

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ANON_KEY=...

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=...
FROM_EMAIL=noreply@yourdomain.com
MAIL_FROM=noreply@yourdomain.com
MAIL_TO=you@yourdomain.com

# ── Platform ───────────────────────────────────────────────────────────────────
SITE_URL=https://your-netlify-site.netlify.app
INTERNAL_SECRET=...                                   # Random secret for internal function calls
PLATFORM_NAME=ProofLink

# ── Tester slots ───────────────────────────────────────────────────────────────
MAX_TESTER_SLOTS=3                                    # Max concurrent billing-exempt testers
