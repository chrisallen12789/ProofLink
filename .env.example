# ProofLink — Required Environment Variables
# Set all of these in your Netlify dashboard:
# Site → Environment variables
#
# ── Payments ───────────────────────────────────────────────────────────────────
# ProofLink is currently in manual-payments mode.
# Online checkout and automated billing are intentionally disabled while
# replacement payment options are evaluated.

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ANON_KEY=...

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=...
FROM_EMAIL=ProofLink <support@prooflink.co>
REPLY_TO_EMAIL=support@prooflink.co
MAIL_FROM=ProofLink <support@prooflink.co>
MAIL_TO=christopher@prooflink.co
OPERATOR_ALERT_EMAIL=christopher@prooflink.co

# ── Domain ─────────────────────────────────────────────────────────────────────
# SITE_URL must be the canonical domain — used in auth redirect links, emails, etc.
SITE_URL=https://prooflink.co
PUBLIC_SITE_URL=https://prooflink.co

# ── Platform ───────────────────────────────────────────────────────────────────
INTERNAL_SECRET=...
PLATFORM_NAME=ProofLink
MAX_TESTER_SLOTS=3
PROOFLINK_DEFAULT_APPLICATION_FEE_BPS=750

# ── Spam protection ────────────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=...
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_CALENDAR_REDIRECT_URI=https://prooflink.co/.netlify/functions/google-calendar-oauth-callback
